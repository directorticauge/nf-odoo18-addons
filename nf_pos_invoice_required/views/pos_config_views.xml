<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Agregar campo en la configuración del POS -->
        <record id="view_pos_config_form_invoice_required" model="ir.ui.view">
            <field name="name">pos.config.form.invoice.required</field>
            <field name="model">pos.config</field>
            <field name="inherit_id" ref="point_of_sale.pos_config_view_form"/>
            <field name="arch" type="xml">
                <!-- Agregar después del campo name -->
                <xpath expr="//field[@name='name']" position="after">
                    <field name="force_invoice_required"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
