<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Categoría de la app en el panel de usuarios -->
        <record id="module_category_nf_reports" model="ir.module.category">
            <field name="name">NF Reportes</field>
            <field name="sequence">100</field>
        </record>

        <!-- Usuario: puede consultar y ejecutar reportes -->
        <record id="group_nf_report_user" model="res.groups">
            <field name="name">Usuario</field>
            <field name="category_id" ref="module_category_nf_reports"/>
            <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
            <field name="comment">Puede ver y ejecutar reportes según los permisos de cada uno.</field>
        </record>

        <!-- Administrador: puede crear, editar y eliminar reportes -->
        <record id="group_nf_report_manager" model="res.groups">
            <field name="name">Administrador</field>
            <field name="category_id" ref="module_category_nf_reports"/>
            <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
            <field name="comment">Puede crear, editar, eliminar reportes y ver el historial completo.</field>
        </record>

    </data>
</odoo>
