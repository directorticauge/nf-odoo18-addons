<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ==================== LIST ==================== -->
        <record id="view_nf_report_log_list" model="ir.ui.view">
            <field name="name">nf.report.log.list</field>
            <field name="model">nf.report.log</field>
            <field name="arch" type="xml">
                <list string="Historial de Ejecuciones" create="false" edit="false" delete="false">
                    <field name="execution_date"/>
                    <field name="report_id"/>
                    <field name="user_id"/>
                    <field name="export_type"/>
                    <field name="row_count"/>
                    <field name="execution_time" string="Tiempo (s)"/>
                    <field name="success" widget="boolean"/>
                    <field name="params_summary"/>
                </list>
            </field>
        </record>

        <!-- ==================== FORM ==================== -->
        <record id="view_nf_report_log_form" model="ir.ui.view">
            <field name="name">nf.report.log.form</field>
            <field name="model">nf.report.log</field>
            <field name="arch" type="xml">
                <form string="Detalle de Ejecución" create="false" edit="false">
                    <sheet>
                        <group>
                            <group string="Información general">
                                <field name="report_id"/>
                                <field name="user_id"/>
                                <field name="execution_date"/>
                                <field name="export_type"/>
                            </group>
                            <group string="Resultado">
                                <field name="success" widget="boolean"/>
                                <field name="row_count"/>
                                <field name="execution_time"/>
                                <field name="params_summary"/>
                            </group>
                        </group>
                        <group string="Error" invisible="not error">
                            <field name="error" nolabel="1"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- ==================== SEARCH ==================== -->
        <record id="view_nf_report_log_search" model="ir.ui.view">
            <field name="name">nf.report.log.search</field>
            <field name="model">nf.report.log</field>
            <field name="arch" type="xml">
                <search string="Buscar historial">
                    <field name="report_id"/>
                    <field name="user_id"/>
                    <filter name="success" string="Exitosas" domain="[('success','=',True)]"/>
                    <filter name="failed" string="Con error" domain="[('success','=',False)]"/>
                    <group expand="0" string="Agrupar por">
                        <filter name="group_report" string="Reporte" context="{'group_by': 'report_id'}"/>
                        <filter name="group_user" string="Usuario" context="{'group_by': 'user_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- ==================== ACTION ==================== -->
        <record id="action_nf_report_log" model="ir.actions.act_window">
            <field name="name">Historial de Ejecuciones</field>
            <field name="res_model">nf.report.log</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_nf_report_log_search"/>
        </record>

    </data>
</odoo>
