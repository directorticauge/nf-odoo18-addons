<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ==================== FORM ==================== -->
        <record id="view_nf_schema_browser_form" model="ir.ui.view">
            <field name="name">nf.schema.browser.form</field>
            <field name="model">nf.schema.browser</field>
            <field name="arch" type="xml">
                <form string="Explorador de Esquema">
                    <sheet>
                        <div style="background:#2c3e50; color:white; padding:10px 14px; border-radius:6px; margin-bottom:12px;">
                            <h3 style="margin:0; font-size:16px;">&#128202; Explorador de Tablas y Campos</h3>
                            <div style="font-size:12px; margin-top:4px; opacity:0.85;">
                                Consulta las tablas de la base de datos y el significado de cada campo.
                            </div>
                        </div>

                        <group col="2">
                            <field name="table_filter" string="Buscar tabla"
                                   placeholder="ej: pos_order, account_move..."/>
                            <field name="column_filter" string="Buscar campo"
                                   placeholder="ej: name, partner_id... (opcional)"/>
                        </group>

                        <div style="margin: 10px 0 14px 0;">
                            <button name="action_search"
                                    type="object"
                                    string="&#128269; Buscar"
                                    class="btn-primary"/>
                        </div>

                        <div invisible="not has_results"
                             style="border:1px solid #ddd; border-radius:6px; overflow:auto; max-height:500px;">
                            <field name="result_html"
                                   nolabel="1"
                                   readonly="1"
                                   widget="html"
                                   sanitize="0"/>
                        </div>

                    </sheet>
                </form>
            </field>
        </record>

        <!-- ==================== ACTION ==================== -->
        <record id="action_nf_schema_browser" model="ir.actions.act_window">
            <field name="name">Explorador de Esquema</field>
            <field name="res_model">nf.schema.browser</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

    </data>
</odoo>
