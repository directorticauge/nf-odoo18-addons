                  sequence="90"
                  groups="nf_reports_custom.group_nf_report_user"
                  web_icon="nf_reports_custom,static/description/icon.png"/>

        <!-- ==================== SUB-MENÚ: REPORTES ==================== -->
        <menuitem id="menu_nf_reportes"
