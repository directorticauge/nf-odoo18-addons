<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_pos_printer_network_form" model="ir.ui.view">
            <field name="name">pos.printer.network.form</field>
            <field name="model">pos.printer</field>
            <field name="inherit_id" ref="point_of_sale.view_pos_printer_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='printer_type']" position="after">
                    <field name="network_print_url"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
