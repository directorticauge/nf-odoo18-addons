<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Vista de formulario de configuración POS -->
        <record id="view_pos_config_form_user_access" model="ir.ui.view">
            <field name="name">pos.config.form.user.access</field>
            <field name="model">pos.config</field>
            <field name="inherit_id" ref="point_of_sale.pos_config_view_form"/>
            <field name="arch" type="xml">
                
                <!-- Agregar grupo con campos de control de acceso después del último grupo -->
                <xpath expr="//form/sheet" position="inside">
                    <group string="Control de Acceso de Usuarios" name="user_access_group">
                        <field name="user_access_restricted" readonly="1"/>
                        <field name="allowed_user_ids" widget="many2many_tags" 
                               options="{'no_create': True, 'no_open': True}"
                               placeholder="Si está vacío, todos los usuarios con permisos de POS pueden acceder"/>
                        <div class="alert alert-info" role="alert" colspan="2">
                            <strong>ℹ️ Información:</strong>
                            <ul>
                                <li>Si NO seleccionas ningún usuario, todos los usuarios con permisos de POS podrán acceder a esta configuración.</li>
                                <li>Si seleccionas usuarios específicos, SOLO esos usuarios podrán abrir sesiones y usar este POS.</li>
                                <li>Los administradores siempre pueden configurar las restricciones, pero también deben estar en la lista para usar el POS.</li>
                            </ul>
                        </div>
                    </group>
                </xpath>
                
                <!-- Agregar indicador visual en el formulario -->
                <xpath expr="//field[@name='name']" position="after">
                    <field name="user_access_restricted" invisible="1"/>
                    <div class="alert alert-warning" role="alert" 
                         invisible="user_access_restricted == False">
                        <strong>🔒 Acceso Restringido:</strong> Este POS tiene usuarios específicos asignados. Solo ellos pueden abrirlo.
                    </div>
                </xpath>
                
            </field>
        </record>
        
        <!-- Vista de lista (tree) para mostrar si tiene restricciones -->
        <record id="view_pos_config_tree_user_access" model="ir.ui.view">
            <field name="name">pos.config.tree.user.access</field>
            <field name="model">pos.config</field>
            <field name="inherit_id" ref="point_of_sale.view_pos_config_tree"/>
            <field name="arch" type="xml">
                <field name="name" position="after">
                    <field name="user_access_restricted" 
                           string="🔒 Restringido"
                           optional="show"/>
                </field>
            </field>
        </record>
        
        <!-- Vista kanban para mostrar restricciones -->
        <record id="view_pos_config_kanban_user_access" model="ir.ui.view">
            <field name="name">pos.config.kanban.user.access</field>
            <field name="model">pos.config</field>
            <field name="inherit_id" ref="point_of_sale.view_pos_config_kanban"/>
            <field name="arch" type="xml">
                <!-- Agregar campos al kanban para que estén disponibles -->
                <xpath expr="//field[@name='name']" position="after">
                    <field name="user_access_restricted"/>
                    <field name="allowed_user_ids"/>
                </xpath>
            </field>
        </record>
        
    </data>
</odoo>
