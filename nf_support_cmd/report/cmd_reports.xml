<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>

<!-- ===================================================================
     PAPER FORMATS
     =================================================================== -->
<record id="paperformat_cmd_a4" model="report.paperformat">
    <field name="name">NF Comodatos A4</field>
    <field name="default" eval="False"/>
    <field name="format">A4</field>
    <field name="page_height">0</field>
    <field name="page_width">0</field>
    <field name="orientation">Portrait</field>
    <field name="margin_top">40</field>
    <field name="margin_bottom">10</field>
    <field name="margin_left">10</field>
    <field name="margin_right">10</field>
    <field name="header_line" eval="False"/>
    <field name="header_spacing">35</field>
    <field name="dpi">96</field>
</record>

<record id="paperformat_cmd_a4_landscape" model="report.paperformat">
    <field name="name">NF Comodatos A4 Landscape</field>
    <field name="default" eval="False"/>
    <field name="format">A4</field>
    <field name="page_height">0</field>
    <field name="page_width">0</field>
    <field name="orientation">Landscape</field>
    <field name="margin_top">40</field>
    <field name="margin_bottom">10</field>
    <field name="margin_left">10</field>
    <field name="margin_right">10</field>
    <field name="header_line" eval="False"/>
    <field name="header_spacing">35</field>
    <field name="dpi">96</field>
</record>


<!-- ===================================================================
     ESTILOS COMUNES
     =================================================================== -->
<template id="cmd_report_assets">
    <style>
        body { font-family: Arial, sans-serif; font-size: 10px; color: #333; }
        h2.report-title { color: #875A7B; border-bottom: 2px solid #875A7B;
                          padding-bottom: 4px; margin-bottom: 10px; font-size: 14px; }
        .info-block { background: #f9f6f9; border: 1px solid #e0d0e0;
                      border-radius: 4px; padding: 6px 10px; margin-bottom: 8px; }
        .info-block span { color: #875A7B; font-weight: bold; }
        table.cmd-table { width: 100%; border-collapse: collapse; margin-top: 6px; }
        table.cmd-table th { background: #875A7B; color: #fff; padding: 5px 6px;
                             text-align: left; font-size: 9px; }
        table.cmd-table td { padding: 4px 6px; border-bottom: 1px solid #e8e8e8;
                             vertical-align: top; font-size: 9px; }
        table.cmd-table tr:nth-child(even) td { background: #faf7fa; }
        .badge-available   { background:#27ae60; color:#fff; border-radius:3px; padding:1px 5px; }
        .badge-assigned    { background:#2980b9; color:#fff; border-radius:3px; padding:1px 5px; }
        .badge-maintenance { background:#e67e22; color:#fff; border-radius:3px; padding:1px 5px; }
        .badge-lost        { background:#c0392b; color:#fff; border-radius:3px; padding:1px 5px; }
        .badge-retired     { background:#95a5a6; color:#fff; border-radius:3px; padding:1px 5px; }
        .badge-active      { background:#27ae60; color:#fff; border-radius:3px; padding:1px 5px; }
        .badge-returned    { background:#7f8c8d; color:#fff; border-radius:3px; padding:1px 5px; }
        .footer-note { font-size: 8px; color: #999; text-align: center; margin-top: 10px; }
        .section-header { background:#ede0ed; color:#5a3a5a; font-weight:bold;
                          padding: 3px 6px; margin: 8px 0 2px 0; font-size: 10px; }
        .total-row td { font-weight: bold; background: #ede0ed !important; }
        .signature-box { border-top: 1px solid #333; margin-top: 40px; padding-top: 4px;
                         text-align: center; font-size: 9px; color: #555; }
    </style>
</template>


<!-- ===================================================================
     REPORTE 1 - RELACION DE EQUIPOS (Inventario completo)
     =================================================================== -->
<record id="action_report_cmd_inventario" model="ir.actions.report">
    <field name="name">Relaci&#243;n de Equipos</field>
    <field name="model">nf.cmd.report.wizard</field>
    <field name="report_type">qweb-pdf</field>
    <field name="report_name">nf_support_cmd.report_cmd_inventario</field>
    <field name="report_file">nf_support_cmd.report_cmd_inventario</field>
    <field name="paperformat_id" ref="paperformat_cmd_a4_landscape"/>
    <field name="binding_model_id" eval="False"/>
</record>

<template id="report_cmd_inventario">
    <t t-call="web.html_container">
        <t t-call="web.external_layout">
            <t t-call="nf_support_cmd.cmd_report_assets"/>
            <div class="page">
                <h2 class="report-title">Relaci&#243;n de Equipos en Comodato</h2>
                <div class="info-block">
                    <span>Generado:</span> <t t-esc="data['fecha_generacion']"/>
                    &#160;&#160;
                    <span>Total equipos:</span> <t t-esc="data['total_equipos']"/>
                    &#160;&#160;
                    <t t-if="data.get('filtro_tipo')">
                        <span>Tipo:</span> <t t-esc="data['filtro_tipo']"/>
                    </t>
                    <t t-if="data.get('filtro_estado')">
                        &#160;&#160;<span>Estado:</span> <t t-esc="data['filtro_estado']"/>
                    </t>
                </div>

                <table class="cmd-table">
                    <thead>
                        <tr>
                            <th>N&#176;</th>
                            <th>Tipo</th>
                            <th>Modelo / N.C.</th>
                            <th>Capacidad</th>
                            <th>Estado</th>
                            <th>Nombre Comercial</th>
                            <th>NIT / C.C.</th>
                            <th>Ruta</th>
                            <th>Ciudad</th>
                            <th>F. Entrega</th>
                            <th>D&#237;as</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="data['equipos']" t-as="e">
                            <tr>
                                <td><t t-esc="e['sequence_number']"/></td>
                                <td><t t-esc="e['tipo']"/></td>
                                <td><t t-esc="e['model_ref']"/></td>
                                <td><t t-esc="e['capacity']"/></td>
                                <td>
                                    <span t-attf-class="badge-#{e['state']}">
                                        <t t-esc="e['state_label']"/>
                                    </span>
                                </td>
                                <td><t t-esc="e['commercial_name']"/></td>
                                <td><t t-esc="e['nit_cc']"/></td>
                                <td><t t-esc="e['route']"/></td>
                                <td><t t-esc="e['city']"/></td>
                                <td><t t-esc="e['delivery_date']"/></td>
                                <td><t t-esc="e['days_assigned']"/></td>
                            </tr>
                        </t>
                    </tbody>
                </table>
                <p class="footer-note">
                    Documento generado autom&#225;ticamente &#8212; NF Gesti&#243;n de Comodatos
                </p>
            </div>
        </t>
    </t>
</template>


<!-- ===================================================================
     REPORTE 2 - COMODATOS ACTIVOS POR RUTA/CIUDAD
     =================================================================== -->
<record id="action_report_cmd_activos" model="ir.actions.report">
    <field name="name">Comodatos Activos</field>
    <field name="model">nf.cmd.report.wizard</field>
    <field name="report_type">qweb-pdf</field>
    <field name="report_name">nf_support_cmd.report_cmd_activos</field>
    <field name="report_file">nf_support_cmd.report_cmd_activos</field>
    <field name="paperformat_id" ref="paperformat_cmd_a4_landscape"/>
    <field name="binding_model_id" eval="False"/>
</record>

<template id="report_cmd_activos">
    <t t-call="web.html_container">
        <t t-call="web.external_layout">
            <t t-call="nf_support_cmd.cmd_report_assets"/>
            <div class="page">
                <h2 class="report-title">Comodatos Activos</h2>
                <div class="info-block">
                    <span>Fecha:</span> <t t-esc="data['fecha_generacion']"/>
                    &#160;&#160;
                    <span>Total activos:</span> <t t-esc="data['total_activos']"/>
                    &#160;&#160;
                    <t t-if="data.get('agrupado_por')">
                        <span>Agrupado por:</span> <t t-esc="data['agrupado_por']"/>
                    </t>
                </div>

                <t t-foreach="data['grupos']" t-as="grupo">
                    <div class="section-header">
                        <t t-esc="grupo['label']"/>
                        &#160;(<t t-esc="grupo['count']"/> equipos)
                    </div>
                    <table class="cmd-table">
                        <thead>
                            <tr>
                                <th>N&#176;</th>
                                <th>Tipo</th>
                                <th>Modelo</th>
                                <th>Cap.</th>
                                <th>Nombre Comercial</th>
                                <th>NIT / C.C.</th>
                                <th>Ruta</th>
                                <th>Ciudad</th>
                                <th>F. Entrega</th>
                                <th>D&#237;as</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="grupo['equipos']" t-as="e">
                                <tr>
                                    <td><t t-esc="e['sequence_number']"/></td>
                                    <td><t t-esc="e['tipo']"/></td>
                                    <td><t t-esc="e['model_ref']"/></td>
                                    <td><t t-esc="e['capacity']"/></td>
                                    <td><t t-esc="e['commercial_name']"/></td>
                                    <td><t t-esc="e['nit_cc']"/></td>
                                    <td><t t-esc="e['route']"/></td>
                                    <td><t t-esc="e['city']"/></td>
                                    <td><t t-esc="e['delivery_date']"/></td>
                                    <td><t t-esc="e['days_assigned']"/></td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </t>
                <p class="footer-note">
                    Documento generado autom&#225;ticamente &#8212; NF Gesti&#243;n de Comodatos
                </p>
            </div>
        </t>
    </t>
</template>


<!-- ===================================================================
     REPORTE 3 - FICHA DE EQUIPO
     =================================================================== -->
<record id="action_report_cmd_ficha_equipo" model="ir.actions.report">
    <field name="name">Ficha de Equipo</field>
    <field name="model">nf.cmd.equipment</field>
    <field name="report_type">qweb-pdf</field>
    <field name="report_name">nf_support_cmd.report_cmd_ficha_equipo</field>
    <field name="report_file">nf_support_cmd.report_cmd_ficha_equipo</field>
    <field name="paperformat_id" ref="paperformat_cmd_a4"/>
    <field name="binding_model_id" ref="nf_support_cmd.model_nf_cmd_equipment"/>
    <field name="binding_type">report</field>
</record>

<template id="report_cmd_ficha_equipo">
    <t t-call="web.html_container">
        <t t-foreach="docs" t-as="equip">
            <t t-call="web.external_layout">
                <t t-call="nf_support_cmd.cmd_report_assets"/>
                <div class="page">
                    <h2 class="report-title">
                        Ficha de Equipo &#8212; <t t-esc="equip.name"/>
                    </h2>

                    <table style="width:100%; margin-bottom:10px;">
                        <tr>
                            <td style="width:50%; vertical-align:top;">
                                <div class="info-block">
                                    <b>Identificaci&#243;n</b><br/>
                                    <span>N&#176; Equipo:</span> <t t-esc="equip.sequence_number"/><br/>
                                    <span>Tipo:</span> <t t-esc="equip.equipment_type_id.name"/><br/>
                                    <span>Modelo / N.C.:</span> <t t-esc="equip.model_ref or '-'"/><br/>
                                    <span>Marca:</span> <t t-esc="equip.brand or '-'"/><br/>
                                    <span>Serial:</span> <t t-esc="equip.serial_number or '-'"/><br/>
                                    <span>Capacidad:</span> <t t-esc="equip.capacity or '-'"/><br/>
                                    <span>Litros:</span> <t t-esc="equip.liters or '-'"/>
                                </div>
                            </td>
                            <td style="width:50%; vertical-align:top;">
                                <div class="info-block">
                                    <b>Estado Actual</b><br/>
                                    <span>Estado:</span>
                                    <t t-esc="dict(equip._fields['state'].selection).get(equip.state, equip.state)"/><br/>
                                    <t t-if="equip.state == 'assigned'">
                                        <span>Cliente:</span> <t t-esc="equip.current_commercial_name or '-'"/><br/>
                                        <span>Ruta:</span> <t t-esc="equip.current_route or '-'"/><br/>
                                        <span>Ciudad:</span> <t t-esc="equip.current_city or '-'"/><br/>
                                        <span>Entregado:</span> <t t-esc="equip.delivery_date"/><br/>
                                        <span>D&#237;as:</span> <t t-esc="equip.days_assigned"/>
                                    </t>
                                    <t t-if="equip.notes">
                                        <br/><span>Obs:</span> <t t-esc="equip.notes"/>
                                    </t>
                                </div>
                            </td>
                        </tr>
                    </table>

                    <div class="section-header">Historial de Asignaciones (<t t-esc="len(equip.assignment_ids)"/>)</div>
                    <table class="cmd-table">
                        <thead>
                            <tr>
                                <th>F. Entrega</th>
                                <th>F. Devoluci&#243;n</th>
                                <th>Nombre Comercial</th>
                                <th>NIT / C.C.</th>
                                <th>Ruta</th>
                                <th>Ciudad</th>
                                <th>D&#237;as</th>
                                <th>Estado</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="equip.assignment_ids.sorted('delivery_date', reverse=True)" t-as="a">
                                <tr>
                                    <td><t t-esc="a.delivery_date"/></td>
                                    <td><t t-esc="a.return_date or '-'"/></td>
                                    <td><t t-esc="a.commercial_name or '-'"/></td>
                                    <td><t t-esc="a.nit_cc or '-'"/></td>
                                    <td><t t-esc="a.route or '-'"/></td>
                                    <td><t t-esc="a.city or '-'"/></td>
                                    <td><t t-esc="a.days_assigned"/></td>
                                    <td>
                                        <span t-attf-class="badge-#{a.state}">
                                            <t t-esc="dict(a._fields['state'].selection).get(a.state, a.state)"/>
                                        </span>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>

                    <div class="section-header" style="margin-top:12px;">Servicios T&#233;cnicos (<t t-esc="len(equip.service_ids)"/>)</div>
                    <table class="cmd-table">
                        <thead>
                            <tr>
                                <th>Fecha</th>
                                <th>Tipo</th>
                                <th>T&#233;cnico</th>
                                <th>Lugar / Cliente</th>
                                <th>Valor</th>
                                <th>Observaciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="equip.service_ids.sorted('date', reverse=True)" t-as="s">
                                <tr>
                                    <td><t t-esc="s.date"/></td>
                                    <td><t t-esc="dict(s._fields['service_type'].selection).get(s.service_type, s.service_type)"/></td>
                                    <td><t t-esc="s.worker or '-'"/></td>
                                    <td><t t-esc="s.client_name or (s.partner_id.name if s.partner_id else '-')"/></td>
                                    <td style="text-align:right;">
                                        <t t-if="s.value">
                                            $<t t-esc="'{:,.0f}'.format(s.value)"/>
                                        </t>
                                        <t t-else="">-</t>
                                    </td>
                                    <td><t t-esc="s.notes or '-'"/></td>
                                </tr>
                            </t>
                        </tbody>
                    </table>

                    <p class="footer-note">
                        Documento generado autom&#225;ticamente &#8212; NF Gesti&#243;n de Comodatos
                    </p>
                </div>
            </t>
        </t>
    </t>
</template>


<!-- ===================================================================
     REPORTE 4 - ACTA DE ENTREGA / DEVOLUCION
     =================================================================== -->
<record id="action_report_cmd_acta" model="ir.actions.report">
    <field name="name">Acta de Entrega / Devoluci&#243;n</field>
    <field name="model">nf.cmd.assignment</field>
    <field name="report_type">qweb-pdf</field>
    <field name="report_name">nf_support_cmd.report_cmd_acta</field>
    <field name="report_file">nf_support_cmd.report_cmd_acta</field>
    <field name="paperformat_id" ref="paperformat_cmd_a4"/>
    <field name="binding_model_id" ref="nf_support_cmd.model_nf_cmd_assignment"/>
    <field name="binding_type">report</field>
</record>

<template id="report_cmd_acta">
    <t t-call="web.html_container">
        <t t-foreach="docs" t-as="asig">
            <t t-call="web.external_layout">
                <t t-call="nf_support_cmd.cmd_report_assets"/>
                <div class="page">
                    <h2 class="report-title">
                        <t t-if="asig.state == 'returned'">Acta de Devoluci&#243;n</t>
                        <t t-else="">Acta de Entrega en Comodato</t>
                    </h2>

                    <table style="width:100%; margin-bottom:14px;">
                        <tr>
                            <td style="width:60%; vertical-align:top;">
                                <div class="info-block">
                                    <b>Datos del Cliente</b><br/>
                                    <span>Nombre Comercial:</span> <t t-esc="asig.commercial_name or '-'"/><br/>
                                    <span>NIT / C.C.:</span> <t t-esc="asig.nit_cc or '-'"/><br/>
                                    <t t-if="asig.partner_id">
                                        <span>Cliente Odoo:</span> <t t-esc="asig.partner_id.name"/><br/>
                                        <t t-if="asig.partner_id.street">
                                            <span>Direcci&#243;n:</span> <t t-esc="asig.partner_id.street"/><br/>
                                        </t>
                                        <t t-if="asig.partner_id.phone">
                                            <span>Tel&#233;fono:</span> <t t-esc="asig.partner_id.phone"/><br/>
                                        </t>
                                    </t>
                                    <span>Ciudad:</span> <t t-esc="asig.city or '-'"/><br/>
                                    <span>Ruta:</span> <t t-esc="asig.route or '-'"/>
                                </div>
                            </td>
                            <td style="width:40%; vertical-align:top;">
                                <div class="info-block">
                                    <b>Fechas</b><br/>
                                    <span>Fecha de Entrega:</span> <t t-esc="asig.delivery_date"/><br/>
                                    <t t-if="asig.return_date">
                                        <span>Fecha de Devoluci&#243;n:</span> <t t-esc="asig.return_date"/><br/>
                                    </t>
                                    <span>D&#237;as en comodato:</span> <t t-esc="asig.days_assigned"/><br/>
                                    <span>Estado:</span>
                                    <t t-esc="dict(asig._fields['state'].selection).get(asig.state, asig.state)"/>
                                </div>
                            </td>
                        </tr>
                    </table>

                    <div class="section-header">Equipo Entregado en Comodato</div>
                    <table class="cmd-table" style="margin-bottom:20px;">
                        <thead>
                            <tr>
                                <th>N&#176; Equipo</th>
                                <th>Tipo</th>
                                <th>Modelo / N.C.</th>
                                <th>Marca</th>
                                <th>Serial</th>
                                <th>Capacidad</th>
                                <th>Litros</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td><t t-esc="asig.equipment_id.sequence_number"/></td>
                                <td><t t-esc="asig.equipment_id.equipment_type_id.name"/></td>
                                <td><t t-esc="asig.equipment_id.model_ref or '-'"/></td>
                                <td><t t-esc="asig.equipment_id.brand or '-'"/></td>
                                <td><t t-esc="asig.equipment_id.serial_number or '-'"/></td>
                                <td><t t-esc="asig.equipment_id.capacity or '-'"/></td>
                                <td><t t-esc="asig.equipment_id.liters or '-'"/></td>
                            </tr>
                        </tbody>
                    </table>

                    <div class="section-header">Condiciones del Comodato</div>
                    <div class="info-block" style="min-height:40px;">
                        <t t-if="asig.notes">
                            <t t-esc="asig.notes"/>
                        </t>
                        <t t-else="">
                            <span style="color:#aaa;">
                                El equipo se entrega en buen estado de funcionamiento para uso exclusivo
                                del establecimiento arriba indicado.
                            </span>
                        </t>
                    </div>

                    <table style="width:100%; margin-top:40px;">
                        <tr>
                            <td style="width:45%; text-align:center;">
                                <div class="signature-box">
                                    Firma y sello &#8212; Entrega<br/>
                                    <b>HIELO INDUROD S.A.S.</b>
                                </div>
                            </td>
                            <td style="width:10%;"></td>
                            <td style="width:45%; text-align:center;">
                                <div class="signature-box">
                                    Firma &#8212; Recibido / Devuelto<br/>
                                    <b><t t-esc="asig.commercial_name or 'Cliente'"/></b>
                                </div>
                            </td>
                        </tr>
                    </table>

                    <p class="footer-note">
                        Documento generado autom&#225;ticamente &#8212; NF Gesti&#243;n de Comodatos
                    </p>
                </div>
            </t>
        </t>
    </t>
</template>


<!-- ===================================================================
     REPORTE 5 - INFORME DE SERVICIOS
     =================================================================== -->
<record id="action_report_cmd_servicios" model="ir.actions.report">
    <field name="name">Informe de Servicios</field>
    <field name="model">nf.cmd.report.wizard</field>
    <field name="report_type">qweb-pdf</field>
    <field name="report_name">nf_support_cmd.report_cmd_servicios</field>
    <field name="report_file">nf_support_cmd.report_cmd_servicios</field>
    <field name="paperformat_id" ref="paperformat_cmd_a4_landscape"/>
    <field name="binding_model_id" eval="False"/>
</record>

<template id="report_cmd_servicios">
    <t t-call="web.html_container">
        <t t-call="web.external_layout">
            <t t-call="nf_support_cmd.cmd_report_assets"/>
            <div class="page">
                <h2 class="report-title">Informe de Servicios T&#233;cnicos</h2>
                <div class="info-block">
                    <span>Per&#237;odo:</span>
                    <t t-esc="data['fecha_desde']"/> &#8212; <t t-esc="data['fecha_hasta']"/>
                    &#160;&#160;
                    <span>Total servicios:</span> <t t-esc="data['total_servicios']"/>
                    &#160;&#160;
                    <span>Total valor:</span> $<t t-esc="data['total_valor']"/>
                    <t t-if="data.get('filtro_tecnico')">
                        &#160;&#160;<span>T&#233;cnico:</span> <t t-esc="data['filtro_tecnico']"/>
                    </t>
                    <t t-if="data.get('filtro_tipo_servicio')">
                        &#160;&#160;<span>Tipo:</span> <t t-esc="data['filtro_tipo_servicio']"/>
                    </t>
                </div>

                <table class="cmd-table">
                    <thead>
                        <tr>
                            <th>Fecha</th>
                            <th>Tipo</th>
                            <th>Equipo</th>
                            <th>Tipo Equipo</th>
                            <th>Lugar / Cliente</th>
                            <th>T&#233;cnico</th>
                            <th style="text-align:right;">Valor</th>
                            <th>Observaciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="data['servicios']" t-as="s">
                            <tr>
                                <td><t t-esc="s['date']"/></td>
                                <td><t t-esc="s['service_type_label']"/></td>
                                <td><t t-esc="s['equipo']"/></td>
                                <td><t t-esc="s['tipo_equipo']"/></td>
                                <td><t t-esc="s['client_name']"/></td>
                                <td><t t-esc="s['worker']"/></td>
                                <td style="text-align:right;">
                                    <t t-if="s['value']">$<t t-esc="s['value_fmt']"/></t>
                                    <t t-else="">-</t>
                                </td>
                                <td><t t-esc="s['notes']"/></td>
                            </tr>
                        </t>
                        <tr class="total-row">
                            <td colspan="6">TOTAL</td>
                            <td style="text-align:right;">$<t t-esc="data['total_valor']"/></td>
                            <td></td>
                        </tr>
                    </tbody>
                </table>
                <p class="footer-note">
                    Documento generado autom&#225;ticamente &#8212; NF Gesti&#243;n de Comodatos
                </p>
            </div>
        </t>
    </t>
</template>


<!-- ===================================================================
     REPORTE 6/7/8 - ALERTAS
     =================================================================== -->
<record id="action_report_cmd_alertas" model="ir.actions.report">
    <field name="name">Reporte de Alertas de Equipos</field>
    <field name="model">nf.cmd.report.wizard</field>
    <field name="report_type">qweb-pdf</field>
    <field name="report_name">nf_support_cmd.report_cmd_alertas</field>
    <field name="report_file">nf_support_cmd.report_cmd_alertas</field>
    <field name="paperformat_id" ref="paperformat_cmd_a4"/>
    <field name="binding_model_id" eval="False"/>
</record>

<template id="report_cmd_alertas">
    <t t-call="web.html_container">
        <t t-call="web.external_layout">
            <t t-call="nf_support_cmd.cmd_report_assets"/>
            <div class="page">
                <h2 class="report-title">Alertas de Equipos en Comodato</h2>
                <div class="info-block">
                    <span>Generado:</span> <t t-esc="data['fecha_generacion']"/>
                    &#160;&#160;
                    <span>Meses sin mov. (umbral):</span> <t t-esc="data['umbral_meses']"/>
                </div>

                <t t-if="data['perdidos']">
                    <div class="section-header" style="background:#fde8e8; color:#8b0000;">
                        Equipos Por Localizar (<t t-esc="len(data['perdidos'])"/>)
                    </div>
                    <table class="cmd-table">
                        <thead><tr>
                            <th>N&#176;</th><th>Tipo</th><th>Modelo</th>
                            <th>&#218;ltima Ubicaci&#243;n</th><th>&#218;ltima F. Entrega</th><th>D&#237;as</th>
                        </tr></thead>
                        <tbody>
                            <t t-foreach="data['perdidos']" t-as="e">
                                <tr>
                                    <td><t t-esc="e['sequence_number']"/></td>
                                    <td><t t-esc="e['tipo']"/></td>
                                    <td><t t-esc="e['model_ref']"/></td>
                                    <td><t t-esc="e['commercial_name']"/> &#8212; <t t-esc="e['city']"/></td>
                                    <td><t t-esc="e['delivery_date']"/></td>
                                    <td><t t-esc="e['days_assigned']"/></td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </t>

                <t t-if="data['antiguos']">
                    <div class="section-header" style="background:#fff3cd; color:#856404; margin-top:14px;">
                        Comodatos con m&#225;s de <t t-esc="data['umbral_meses']"/> meses (<t t-esc="len(data['antiguos'])"/>)
                    </div>
                    <table class="cmd-table">
                        <thead><tr>
                            <th>N&#176;</th><th>Tipo</th><th>Nombre Comercial</th>
                            <th>Ciudad</th><th>Ruta</th><th>F. Entrega</th><th>D&#237;as</th>
                        </tr></thead>
                        <tbody>
                            <t t-foreach="data['antiguos']" t-as="e">
                                <tr>
                                    <td><t t-esc="e['sequence_number']"/></td>
                                    <td><t t-esc="e['tipo']"/></td>
                                    <td><t t-esc="e['commercial_name']"/></td>
                                    <td><t t-esc="e['city']"/></td>
                                    <td><t t-esc="e['route']"/></td>
                                    <td><t t-esc="e['delivery_date']"/></td>
                                    <td><t t-esc="e['days_assigned']"/></td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </t>

                <t t-if="data['sin_movimiento']">
                    <div class="section-header" style="background:#e8f4f8; color:#0c5460; margin-top:14px;">
                        Disponibles en Patio (sin asignar, <t t-esc="len(data['sin_movimiento'])"/>)
                    </div>
                    <table class="cmd-table">
                        <thead><tr>
                            <th>N&#176;</th><th>Tipo</th><th>Modelo</th><th>Capacidad</th><th>Observaciones</th>
                        </tr></thead>
                        <tbody>
                            <t t-foreach="data['sin_movimiento']" t-as="e">
                                <tr>
                                    <td><t t-esc="e['sequence_number']"/></td>
                                    <td><t t-esc="e['tipo']"/></td>
                                    <td><t t-esc="e['model_ref']"/></td>
                                    <td><t t-esc="e['capacity']"/></td>
                                    <td><t t-esc="e['notes']"/></td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </t>

                <p class="footer-note">
                    Documento generado autom&#225;ticamente &#8212; NF Gesti&#243;n de Comodatos
                </p>
            </div>
        </t>
    </t>
</template>


<!-- ===================================================================
     REPORTE 9 - RESUMEN EJECUTIVO
     =================================================================== -->
<record id="action_report_cmd_resumen" model="ir.actions.report">
    <field name="name">Resumen Ejecutivo de Comodatos</field>
    <field name="model">nf.cmd.report.wizard</field>
    <field name="report_type">qweb-pdf</field>
    <field name="report_name">nf_support_cmd.report_cmd_resumen</field>
    <field name="report_file">nf_support_cmd.report_cmd_resumen</field>
    <field name="paperformat_id" ref="paperformat_cmd_a4"/>
    <field name="binding_model_id" eval="False"/>
</record>

<template id="report_cmd_resumen">
    <t t-call="web.html_container">
        <t t-call="web.external_layout">
            <t t-call="nf_support_cmd.cmd_report_assets"/>
            <div class="page">
                <h2 class="report-title">Resumen Ejecutivo &#8212; Comodatos</h2>
                <div class="info-block">
                    <span>Generado:</span> <t t-esc="data['fecha_generacion']"/>
                    &#160;&#160;
                    <span>Per&#237;odo servicios:</span>
                    <t t-esc="data['fecha_desde']"/> &#8212; <t t-esc="data['fecha_hasta']"/>
                </div>

                <div class="section-header">Estado del Inventario</div>
                <table class="cmd-table" style="width:50%;">
                    <thead><tr>
                        <th>Estado</th>
                        <th style="text-align:right;">Equipos</th>
                    </tr></thead>
                    <tbody>
                        <t t-foreach="data['por_estado']" t-as="row">
                            <tr>
                                <td><t t-esc="row['label']"/></td>
                                <td style="text-align:right; font-weight:bold;"><t t-esc="row['count']"/></td>
                            </tr>
                        </t>
                        <tr class="total-row">
                            <td>TOTAL</td>
                            <td style="text-align:right;"><t t-esc="data['total_equipos']"/></td>
                        </tr>
                    </tbody>
                </table>

                <div class="section-header" style="margin-top:14px;">Equipos por Tipo</div>
                <table class="cmd-table" style="width:60%;">
                    <thead><tr>
                        <th>Tipo</th>
                        <th style="text-align:right;">Total</th>
                        <th style="text-align:right;">Asignados</th>
                        <th style="text-align:right;">Disponibles</th>
                    </tr></thead>
                    <tbody>
                        <t t-foreach="data['por_tipo']" t-as="row">
                            <tr>
                                <td><t t-esc="row['tipo']"/></td>
                                <td style="text-align:right;"><t t-esc="row['total']"/></td>
                                <td style="text-align:right;"><t t-esc="row['asignados']"/></td>
                                <td style="text-align:right;"><t t-esc="row['disponibles']"/></td>
                            </tr>
                        </t>
                    </tbody>
                </table>

                <div class="section-header" style="margin-top:14px;">Servicios del Per&#237;odo</div>
                <table class="cmd-table" style="width:60%;">
                    <thead><tr>
                        <th>Tipo de Servicio</th>
                        <th style="text-align:right;">Cantidad</th>
                        <th style="text-align:right;">Valor</th>
                    </tr></thead>
                    <tbody>
                        <t t-foreach="data['servicios_por_tipo']" t-as="row">
                            <tr>
                                <td><t t-esc="row['tipo']"/></td>
                                <td style="text-align:right;"><t t-esc="row['count']"/></td>
                                <td style="text-align:right;">$<t t-esc="row['valor_fmt']"/></td>
                            </tr>
                        </t>
                        <tr class="total-row">
                            <td>TOTAL</td>
                            <td style="text-align:right;"><t t-esc="data['total_servicios']"/></td>
                            <td style="text-align:right;">$<t t-esc="data['total_valor_servicios']"/></td>
                        </tr>
                    </tbody>
                </table>

                <t t-if="data['top_rutas']">
                    <div class="section-header" style="margin-top:14px;">Top Rutas por Equipos Activos</div>
                    <table class="cmd-table" style="width:40%;">
                        <thead><tr>
                            <th>Ruta</th>
                            <th style="text-align:right;">Equipos</th>
                        </tr></thead>
                        <tbody>
                            <t t-foreach="data['top_rutas']" t-as="row">
                                <tr>
                                    <td><t t-esc="row['ruta']"/></td>
                                    <td style="text-align:right;"><t t-esc="row['count']"/></td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </t>

                <p class="footer-note">
                    Documento generado autom&#225;ticamente &#8212; NF Gesti&#243;n de Comodatos
                </p>
            </div>
        </t>
    </t>
</template>

</data>
</odoo>
