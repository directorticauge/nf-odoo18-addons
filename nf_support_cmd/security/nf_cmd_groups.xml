<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Categoría de la app -->
        <record id="module_category_nf_cmd" model="ir.module.category">
            <field name="name">NF Comodatos</field>
            <field name="sequence">85</field>
        </record>

        <!-- === USUARIO === -->
        <!-- Puede ver y gestionar equipos, asignaciones y servicios.
             NO puede crear/editar/eliminar Tipos de Equipo. -->
        <record id="group_cmd_user" model="res.groups">
            <field name="name">Usuario</field>
            <field name="category_id" ref="module_category_nf_cmd"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- === GESTOR === -->
        <!-- Hereda al Usuario. Además puede administrar el catálogo de
             Tipos de Equipo y accede al menú Configuración. -->
        <record id="group_cmd_manager" model="res.groups">
            <field name="name">Gestor</field>
            <field name="category_id" ref="module_category_nf_cmd"/>
            <field name="implied_ids" eval="[(4, ref('group_cmd_user'))]"/>
            <field name="users" eval="[(4, ref('base.user_root')),
                                       (4, ref('base.user_admin'))]"/>
        </record>

    </data>
</odoo>
