<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ==================== FORM DEL WIZARD ==================== -->
        <record id="view_cmd_report_wizard_form" model="ir.ui.view">
            <field name="name">nf.cmd.report.wizard.form</field>
            <field name="model">nf.cmd.report.wizard</field>
            <field name="arch" type="xml">
                <form string="Generar Reporte de Comodatos">
                    <sheet>
                        <div class="oe_title">
                            <h1>Reportes de Comodatos</h1>
                        </div>

                        <group>
                            <field name="report_type" string="Tipo de Reporte"/>
                        </group>

                        <!-- Filtros equipos (todos los reportes) -->
                        <group string="Filtros de Equipos"
                               invisible="report_type not in ('inventario','activos','alertas','resumen')">
                            <group>
                                <field name="equipment_type_ids"
                                       string="Tipos de Equipo"
                                       widget="many2many_tags"
                                       placeholder="Todos los tipos..."/>
                            </group>
                            <group>
                                <field name="filter_state"
                                       string="Estado"
                                       invisible="report_type in ('activos',)"/>
                            </group>
                        </group>

                        <!-- Opciones reporte activos -->
                        <group string="Opciones de Agrupación"
                               invisible="report_type != 'activos'">
                            <field name="group_by" string="Agrupar por"/>
                        </group>

                        <!-- Filtros servicios -->
                        <group string="Filtros de Servicios"
                               invisible="report_type not in ('servicios','resumen')">
                            <group>
                                <field name="date_from" string="Desde"/>
                                <field name="date_to" string="Hasta"/>
                            </group>
                            <group>
                                <field name="filter_worker"
                                       string="Técnico"
                                       invisible="report_type != 'servicios'"
                                       placeholder="Filtrar por técnico..."/>
                                <field name="filter_service_type"
                                       string="Tipo de Servicio"
                                       invisible="report_type != 'servicios'"/>
                                <field name="equipment_type_ids"
                                       string="Tipos de Equipo"
                                       widget="many2many_tags"
                                       invisible="report_type != 'servicios'"
                                       placeholder="Todos los tipos..."/>
                            </group>
                        </group>

                        <!-- Opciones alertas -->
                        <group string="Opciones de Alertas"
                               invisible="report_type != 'alertas'">
                            <field name="umbral_meses"
                                   string="Meses sin devolución (umbral)"
                                   help="Equipos asignados desde hace más de N meses se mostrarán como alerta"/>
                        </group>

                        <!-- Descripción dinámica -->
                        <div class="alert alert-info" style="margin-top:12px;">
                            <strong>Inventario completo</strong> — Lista todos los equipos con estado,
                            cliente actual, ruta y ciudad. Ideal para revisión general del parque.
                            <span invisible="report_type != 'activos'">
                                <strong>Comodatos Activos</strong> — Solo equipos asignados, agrupados
                                por Ruta, Ciudad o Tipo. Útil para jefes de ruta.
                            </span>
                            <span invisible="report_type != 'servicios'">
                                <strong>Informe de Servicios</strong> — Servicios técnicos del período
                                con totales de valor. Filtrable por técnico y tipo.
                            </span>
                            <span invisible="report_type != 'alertas'">
                                <strong>Alertas</strong> — Equipos por localizar, comodatos muy
                                antiguos y equipos sin asignar en patio.
                            </span>
                            <span invisible="report_type != 'resumen'">
                                <strong>Resumen Ejecutivo</strong> — Totales por estado, tipo y
                                servicios del período. Una sola página para gerencia.
                            </span>
                        </div>
                    </sheet>

                    <footer>
                        <button name="action_print"
                                type="object"
                                string="Generar PDF"
                                class="btn-primary"
                                icon="fa-file-pdf-o"/>
                        <button string="Cancelar"
                                class="btn-secondary"
                                special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <!-- ==================== ACTION WIZARD ==================== -->
        <record id="action_cmd_report_wizard" model="ir.actions.act_window">
            <field name="name">Generar Reportes</field>
            <field name="res_model">nf.cmd.report.wizard</field>
            <field name="view_mode">form</field>
            <field name="view_ids" eval="[
                (5, 0, 0),
                (0, 0, {'view_mode': 'form', 'view_id': ref('view_cmd_report_wizard_form')}),
            ]"/>
            <field name="target">new</field>
        </record>

    </data>
</odoo>
