<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ==================== LIST VIEW ==================== -->
        <record id="view_cmd_equipment_type_list" model="ir.ui.view">
            <field name="name">nf.cmd.equipment.type.list</field>
            <field name="model">nf.cmd.equipment.type</field>
            <field name="arch" type="xml">
                <list string="Tipos de Equipo">
                    <field name="sequence" widget="handle"/>
                    <field name="name" string="Nombre del Tipo"/>
                    <field name="equipment_count" string="Equipos"/>
                </list>
            </field>
        </record>

        <!-- ==================== FORM VIEW ==================== -->
        <record id="view_cmd_equipment_type_form" model="ir.ui.view">
            <field name="name">nf.cmd.equipment.type.form</field>
            <field name="model">nf.cmd.equipment.type</field>
            <field name="arch" type="xml">
                <form string="Tipo de Equipo">
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button type="object"
                                    name="action_view_equipments"
                                    class="oe_stat_button"
                                    icon="fa-cubes"
                                    invisible="equipment_count == 0">
                                <field name="equipment_count" string="Equipos" widget="statinfo"/>
                            </button>
                        </div>
                        <div class="oe_title">
                            <label for="name" string="Tipo de Equipo"/>
                            <h1><field name="name" placeholder="Ej: Nevera Star, Dispensador..."/></h1>
                        </div>
                        <group>
                            <field name="sequence" string="Orden"/>
                            <field name="active" string="Activo"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- ==================== ACTION ==================== -->
        <record id="action_cmd_equipment_type" model="ir.actions.act_window">
            <field name="name">Tipos de Equipo</field>
            <field name="res_model">nf.cmd.equipment.type</field>
            <field name="view_mode">list,form</field>
            <field name="view_ids" eval="[
                (5, 0, 0),
                (0, 0, {'view_mode': 'list', 'view_id': ref('view_cmd_equipment_type_list')}),
                (0, 0, {'view_mode': 'form', 'view_id': ref('view_cmd_equipment_type_form')}),
            ]"/>
        </record>

    </data>
</odoo>
