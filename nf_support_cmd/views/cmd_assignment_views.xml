<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ==================== LIST VIEW ==================== -->
        <record id="view_cmd_assignment_list" model="ir.ui.view">
            <field name="name">nf.cmd.assignment.list</field>
            <field name="model">nf.cmd.assignment</field>
            <field name="arch" type="xml">
                <list string="Asignaciones de Comodato"
                      decoration-success="state == 'active'"
                      decoration-muted="state != 'active'">
                    <field name="delivery_date" string="F. Entrega"/>
                    <field name="equipment_id" string="Equipo"/>
                    <field name="equipment_type_id" string="Tipo" optional="show"/>
                    <field name="commercial_name" string="Nombre Comercial"/>
                    <field name="partner_id" string="Cliente" optional="show"/>
                    <field name="nit_cc" string="NIT / C.C." optional="show"/>
                    <field name="route" string="Ruta"/>
                    <field name="city" string="Ciudad"/>
                    <field name="days_assigned" string="Días"/>
                    <field name="return_date" string="F. Devolución" optional="show"/>
                    <field name="state" string="Estado" widget="badge"/>
                </list>
            </field>
        </record>

        <!-- ==================== FORM VIEW ==================== -->
        <record id="view_cmd_assignment_form" model="ir.ui.view">
            <field name="name">nf.cmd.assignment.form</field>
            <field name="model">nf.cmd.assignment</field>
            <field name="arch" type="xml">
                <form string="Asignación de Comodato">
                    <header>
                        <button name="action_return"
                                type="object"
                                string="Registrar Devolución"
                                class="btn-warning"
                                invisible="state != 'active'"
                                confirm="¿Confirma que el equipo fue devuelto?"/>
                        <button name="action_cancel"
                                type="object"
                                string="Cancelar"
                                class="btn-danger"
                                invisible="state != 'active'"/>
                        <field name="state" widget="statusbar"
                               statusbar_visible="active,returned"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <label for="equipment_id" string="Equipo"/>
                            <h2><field name="equipment_id"/></h2>
                        </div>
                        <group>
                            <group string="Cliente">
                                <field name="partner_id" string="Cliente en Odoo"
                                       placeholder="Buscar cliente..."/>
                                <field name="commercial_name" string="Nombre Comercial"
                                       placeholder="Nombre del establecimiento..."/>
                                <field name="nit_cc" string="NIT / C.C."/>
                            </group>
                            <group string="Ubicación y Fechas">
                                <field name="delivery_date" string="Fecha de Entrega"/>
                                <field name="return_date" string="Fecha de Devolución"
                                       invisible="state == 'active'"/>
                                <field name="days_assigned" string="Días Asignado" readonly="1"/>
                                <field name="route" string="Ruta"
                                       placeholder="BH, TRONCAL, VIAJES, ..."/>
                                <field name="city" string="Ciudad"/>
                            </group>
                        </group>
                        <group string="Observaciones">
                            <field name="notes" nolabel="1"
                                   placeholder="Condiciones del comodato, entregado con botellón, etc."/>
                        </group>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <!-- ==================== SEARCH VIEW ==================== -->
        <record id="view_cmd_assignment_search" model="ir.ui.view">
            <field name="name">nf.cmd.assignment.search</field>
            <field name="model">nf.cmd.assignment</field>
            <field name="arch" type="xml">
                <search string="Buscar Asignaciones">
                    <field name="commercial_name" string="Nombre Comercial"/>
                    <field name="partner_id" string="Cliente"/>
                    <field name="equipment_id" string="Equipo"/>
                    <field name="city" string="Ciudad"/>
                    <field name="route" string="Ruta"/>
                    <separator/>
                    <filter name="active" string="Activas"
                            domain="[('state','=','active')]"/>
                    <filter name="returned" string="Devueltas"
                            domain="[('state','=','returned')]"/>
                    <group expand="0" string="Agrupar por">
                        <filter name="group_type" string="Tipo"
                                context="{'group_by': 'equipment_type_id'}"/>
                        <filter name="group_state" string="Estado"
                                context="{'group_by': 'state'}"/>
                        <filter name="group_city" string="Ciudad"
                                context="{'group_by': 'city'}"/>
                        <filter name="group_route" string="Ruta"
                                context="{'group_by': 'route'}"/>
                        <filter name="group_partner" string="Cliente"
                                context="{'group_by': 'partner_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- ==================== ACTION ==================== -->
        <record id="action_cmd_assignment" model="ir.actions.act_window">
            <field name="name">Asignaciones</field>
            <field name="res_model">nf.cmd.assignment</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_cmd_assignment_search"/>
            <field name="context">{'search_default_active': 1}</field>
            <field name="view_ids" eval="[
                (5, 0, 0),
                (0, 0, {'view_mode': 'list', 'view_id': ref('view_cmd_assignment_list')}),
                (0, 0, {'view_mode': 'form', 'view_id': ref('view_cmd_assignment_form')}),
            ]"/>
        </record>

    </data>
</odoo>
