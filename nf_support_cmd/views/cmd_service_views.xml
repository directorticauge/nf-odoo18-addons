<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ==================== LIST VIEW ==================== -->
        <record id="view_cmd_service_list" model="ir.ui.view">
            <field name="name">nf.cmd.service.list</field>
            <field name="model">nf.cmd.service</field>
            <field name="arch" type="xml">
                <list string="Salidas de Servicio">
                    <field name="date" string="Fecha"/>
                    <field name="service_type" string="Tipo" widget="badge"/>
                    <field name="equipment_id" string="Equipo"/>
                    <field name="equipment_type_id" string="Tipo Equipo" optional="show"/>
                    <field name="client_name" string="Lugar / Cliente"/>
                    <field name="partner_id" string="Cliente" optional="show"/>
                    <field name="worker" string="Técnico"/>
                    <field name="value" string="Valor" optional="show"/>
                    <field name="notes" string="Observaciones" optional="show"/>
                </list>
            </field>
        </record>

        <!-- ==================== FORM VIEW ==================== -->
        <record id="view_cmd_service_form" model="ir.ui.view">
            <field name="name">nf.cmd.service.form</field>
            <field name="model">nf.cmd.service</field>
            <field name="arch" type="xml">
                <form string="Salida de Servicio">
                    <sheet>
                        <group>
                            <group string="Servicio">
                                <field name="date" string="Fecha"/>
                                <field name="service_type" string="Tipo de Servicio"/>
                                <field name="worker" string="Técnico / Trabajador"
                                       placeholder="Nombre del técnico..."/>
                                <field name="value" string="Valor del Servicio"/>
                            </group>
                            <group string="Equipo y Cliente">
                                <field name="equipment_id" string="Equipo"/>
                                <field name="partner_id" string="Cliente en Odoo"
                                       placeholder="Buscar cliente..."/>
                                <field name="client_name" string="Nombre del Lugar"
                                       placeholder="Nombre del establecimiento / lugar..."/>
                            </group>
                        </group>
                        <group string="Observaciones">
                            <field name="notes" nolabel="1"
                                   placeholder="Notas del servicio, piezas reemplazadas, etc."/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- ==================== SEARCH VIEW ==================== -->
        <record id="view_cmd_service_search" model="ir.ui.view">
            <field name="name">nf.cmd.service.search</field>
            <field name="model">nf.cmd.service</field>
            <field name="arch" type="xml">
                <search string="Buscar Servicios">
                    <field name="client_name" string="Lugar / Cliente"/>
                    <field name="equipment_id" string="Equipo"/>
                    <field name="worker" string="Técnico"/>
                    <separator/>
                    <filter name="maintenance" string="Mantenimientos"
                            domain="[('service_type','=','maintenance')]"/>
                    <filter name="delivery" string="Entregas"
                            domain="[('service_type','=','delivery')]"/>
                    <filter name="pickup" string="Recogidas"
                            domain="[('service_type','=','pickup')]"/>
                    <filter name="repair" string="Reparaciones"
                            domain="[('service_type','=','repair')]"/>
                    <separator/>
                    <filter name="this_month" string="Este mes"
                            domain="[('date','&gt;=', (context_today() + relativedelta(day=1)).strftime('%Y-%m-%d'))]"/>
                    <group expand="0" string="Agrupar por">
                        <filter name="group_type" string="Tipo de Servicio"
                                context="{'group_by': 'service_type'}"/>
                        <filter name="group_equip_type" string="Tipo de Equipo"
                                context="{'group_by': 'equipment_type_id'}"/>
                        <filter name="group_worker" string="Técnico"
                                context="{'group_by': 'worker'}"/>
                        <filter name="group_month" string="Mes"
                                context="{'group_by': 'date:month'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- ==================== ACTION ==================== -->
        <record id="action_cmd_service" model="ir.actions.act_window">
            <field name="name">Salidas de Servicio</field>
            <field name="res_model">nf.cmd.service</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_cmd_service_search"/>
            <field name="view_ids" eval="[
                (5, 0, 0),
                (0, 0, {'view_mode': 'list', 'view_id': ref('view_cmd_service_list')}),
                (0, 0, {'view_mode': 'form', 'view_id': ref('view_cmd_service_form')}),
            ]"/>
        </record>

    </data>
</odoo>
