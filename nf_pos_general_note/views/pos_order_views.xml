<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Agregar campo general_note en la vista de formulario de pos.order -->
    <record id="view_pos_order_form_general_note" model="ir.ui.view">
        <field name="name">pos.order.form.general.note</field>
        <field name="model">pos.order</field>
        <field name="inherit_id" ref="point_of_sale.view_pos_pos_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="general_note" placeholder="Nota general (no genera línea en factura DIAN)" colspan="2"/>
            </xpath>
        </field>
    </record>
    
    <!-- Agregar campo en la vista de árbol -->
    <record id="view_pos_order_tree_general_note" model="ir.ui.view">
        <field name="name">pos.order.tree.general.note</field>
        <field name="model">pos.order</field>
        <field name="inherit_id" ref="point_of_sale.view_pos_order_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="general_note" optional="hide"/>
            </xpath>
        </field>
    </record>
</odoo>
