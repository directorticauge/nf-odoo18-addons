<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ==================== FORM VIEW - WIDGET ==================== -->
        <record id="view_nf_intelligence_widget_form" model="ir.ui.view">
            <field name="name">nf.intelligence.widget.form</field>
            <field name="model">nf.intelligence.widget</field>
            <field name="arch" type="xml">
                <form string="Configurar Widget">
                    <header>
                        <button name="action_detect_columns"
                                type="object"
                                string="🔍 Detectar columnas"
                                class="btn-secondary"
                                help="Ejecuta el SQL, detecta tipos (numérico/texto) y auto-asigna las columnas"/>
                        <button name="action_preview"
                                type="object"
                                string="👁 Vista previa"
                                class="btn-primary"
                                invisible="not detected_columns"
                                help="Renderiza este widget con datos reales para verificar antes de guardar"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <label for="name" string="Título del widget"/>
                            <h2><field name="name" placeholder="Ej: Ventas por método de pago"/></h2>
                        </div>

                        <!-- ── PASO 1: Reporte y tipo ── -->
                        <div style="background:#2c3e50;color:#fff;padding:6px 12px;
                                    border-radius:4px 4px 0 0;font-size:12px;font-weight:bold;
                                    margin-top:8px;">
                            Paso 1 — Seleccione el reporte y el tipo de visualización
                        </div>
                        <div style="border:1px solid #2c3e50;border-top:none;padding:12px;
                                    border-radius:0 0 4px 4px;margin-bottom:12px;">
                            <group>
                                <group>
                                    <field name="report_id"
                                           help="Al seleccionar el reporte, los parámetros se auto-rellenan"/>
                                    <field name="widget_type"/>
                                    <field name="sequence"/>
                                </group>
                                <group string="General">
                                    <field name="col_width"/>
                                    <field name="chart_color" widget="color"
                                           invisible="widget_type == 'table'"/>
                                    <field name="chart_color2" widget="color"
                                           invisible="widget_type not in ['bar','line']"/>
                                    <field name="chart_height"
                                           invisible="widget_type in ['table','kpi','matrix']"/>
                                </group>
                            </group>

                            <!-- Tabla -->
                            <group string="⚙️ Opciones de Tabla" invisible="widget_type != 'table'">
                                <group>
                                    <field name="table_striped"/>
                                    <field name="table_max_rows"/>
                                </group>
                                <group>
                                    <field name="table_header_color" widget="color"/>
                                    <field name="table_font_size"/>
                                </group>
                                <group string="🎨 Formato condicional de color" colspan="2">
                                    <group>
                                        <field name="table_cond_enable"/>
                                        <field name="table_cond_col"
                                               invisible="not table_cond_enable"
                                               placeholder="Nombre exacto de la columna"/>
                                    </group>
                                    <group invisible="not table_cond_enable">
                                        <field name="table_cond_low" string="🔴 Umbral rojo (menor que)"/>
                                        <field name="table_cond_mid" string="🟡 Umbral amarillo (menor que)"/>
                                    </group>
                                </group>
                            </group>

                            <!-- Barras -->
                            <group string="⚙️ Opciones de Barras" invisible="widget_type != 'bar'">
                                <group>
                                    <field name="bar_orientation"/>
                                    <field name="bar_sort"/>
                                    <field name="bar_max_items"/>
                                </group>
                                <group>
                                    <field name="bar_show_values"/>
                                    <field name="bar_rounded"/>
                                </group>
                                <group string="🎯 Línea de objetivo" colspan="2">
                                    <group>
                                        <field name="target_value" string="Valor meta (0 = desactivado)"/>
                                        <field name="target_label" invisible="not target_value"/>
                                    </group>
                                </group>
                            </group>

                            <!-- Línea -->
                            <group string="⚙️ Opciones de Línea" invisible="widget_type != 'line'">
                                <group>
                                    <field name="line_stroke_width"/>
                                    <field name="line_smooth"/>
                                </group>
                                <group>
                                    <field name="line_show_dots"/>
                                    <field name="line_show_area"/>
                                </group>
                                <group string="🎯 Línea de objetivo" colspan="2">
                                    <group>
                                        <field name="target_value" string="Valor meta (0 = desactivado)"/>
                                        <field name="target_label" invisible="not target_value"/>
                                    </group>
                                </group>
                            </group>

                            <!-- Torta -->
                            <group string="⚙️ Opciones de Torta" invisible="widget_type != 'pie'">
                                <group>
                                    <field name="pie_donut"/>
                                    <field name="pie_max_slices"/>
                                </group>
                                <group>
                                    <field name="pie_show_pct"/>
                                    <field name="pie_show_value"/>
                                </group>
                            </group>

                            <!-- KPI -->
                            <group string="⚙️ Opciones de KPI" invisible="widget_type != 'kpi'">
                                <group>
                                    <field name="kpi_icon"/>
                                    <field name="kpi_prefix"/>
                                    <field name="kpi_suffix"/>
                                </group>
                                <group>
                                    <field name="kpi_bg_color" widget="color"/>
                                    <field name="kpi_compare_field_id"
                                           options="{'no_create': True, 'no_open': True}"
                                           invisible="not detected_columns"/>
                                </group>
                            </group>

                            <!-- Pivot -->
                            <group string="⚙️ Opciones de Pivot" invisible="widget_type != 'pivot'">
                                <group>
                                    <field name="pivot_show_totals"/>
                                    <field name="pivot_max_rows"/>
                                </group>
                                <group>
                                    <field name="pivot_header_color" widget="color"/>
                                </group>
                            </group>

                            <!-- Matrix / Mapa de Calor -->
                            <group string="🔥 Opciones de Mapa de Calor" invisible="widget_type != 'matrix'">
                                <group>
                                    <field name="bar_show_values" string="Mostrar valores en celdas"/>
                                    <field name="pivot_max_rows" string="Máx. filas"/>
                                </group>
                                <group>
                                    <field name="pivot_header_color" string="Color cabecera" widget="color"/>
                                    <field name="chart_color" widget="color" string="Color calor (máximo)"/>
                                </group>
                                <div colspan="2"
                                     style="font-size:11px;color:#555;background:#fff3cd;
                                            padding:8px 12px;border-radius:4px;margin-top:4px;
                                            border-left:3px solid #e67e22;">
                                    💡 <b>Mapa de Calor:</b>
                                    <b>Campo Etiqueta</b> = filas &#160;│&#160;
                                    <b>Campo Columnas</b> = columnas &#160;│&#160;
                                    <b>Campo Valor</b> = intensidad de color.
                                    El <b>Color calor</b> define el tono máximo; celdas sin datos aparecen en gris claro.
                                </div>
                            </group>
                        </div>

                        <!-- ── PASO 2: Parámetros del reporte ── -->
                        <div style="background:#27ae60;color:#fff;padding:6px 12px;
                                    border-radius:4px 4px 0 0;font-size:12px;font-weight:bold;">
                            Paso 2 — Complete los parámetros del reporte (se auto-rellenan al elegir el reporte)
                        </div>
                        <div style="border:1px solid #27ae60;border-top:none;padding:12px;
                                    border-radius:0 0 4px 4px;margin-bottom:12px;">
                            <div invisible="widget_param_ids"
                                 style="background:#eafaf1;padding:10px;border-radius:4px;
                                        font-size:12px;color:#888;">
                                ✅ Este reporte no requiere parámetros. Continúe al Paso 3.
                            </div>
                            <field name="widget_param_ids" nolabel="1"
                                   invisible="not widget_param_ids">
                                <list editable="bottom" create="false" delete="false">
                                    <field name="name" readonly="1" string="Parámetro"/>
                                    <field name="param_type" readonly="1" string="Tipo"/>
                                    <field name="value_input" string="Valor"
                                           placeholder="Ej: 2026-01-01 para fecha, texto para otros"/>
                                </list>
                            </field>
                        </div>

                        <!-- ── PASO 3: Detectar y mapear columnas ── -->
                        <div style="background:#2980b9;color:#fff;padding:6px 12px;
                                    border-radius:4px 4px 0 0;font-size:12px;font-weight:bold;">
                            Paso 3 — Pulse "🔍 Detectar columnas" para que aparezcan los selectores
                        </div>
                        <div style="border:1px solid #2980b9;border-top:none;padding:12px;
                                    border-radius:0 0 4px 4px;margin-bottom:12px;">

                            <!-- Mensaje antes de detectar -->
                            <div style="background:#ebf5fb;padding:10px 14px;border-radius:4px;
                                        font-size:12px;color:#2471a3;margin-bottom:10px;"
                                 invisible="detected_columns">
                                ℹ️ Pulse <b>"🔍 Detectar columnas del reporte"</b> en la barra superior.
                                El formulario se recargará con un selector para cada columna del resultado SQL.
                            </div>

                            <!-- Columnas detectadas (referencia) -->
                            <field name="detected_columns" nolabel="1" readonly="1"
                                   invisible="not detected_columns"
                                   style="font-family:monospace;font-size:11px;line-height:1.6;
                                          background:#f0f8ff;border:1px solid #aed6f1;
                                          border-radius:4px;padding:8px;white-space:pre;
                                          display:block;margin-bottom:12px;color:#1a5276;"/>

                            <!-- Selectores de columna (visibles tras detección) -->
                            <group invisible="not detected_columns">
                                <group string="Seleccione la columna para cada rol">
                                    <field name="label_field_id"
                                           invisible="widget_type == 'table'"
                                           options="{'no_create': True, 'no_open': True}"/>
                                    <field name="value_field_id"
                                           invisible="widget_type == 'table'"
                                           options="{'no_create': True, 'no_open': True}"/>
                                    <field name="col_field_id"
                                           invisible="widget_type not in ['pivot', 'matrix']"
                                           options="{'no_create': True, 'no_open': True}"/>
                                    <field name="agg_func"
                                           invisible="widget_type == 'table'"/>
                                </group>
                            </group>
                        </div>

                        <!-- ── PASO 4: Vista previa ── -->
                        <div style="background:#e67e22;color:#fff;padding:6px 12px;
                                    border-radius:4px 4px 0 0;font-size:12px;font-weight:bold;"
                             invisible="not detected_columns">
                            Paso 4 — Vista previa (pulse "👁 Vista previa" en la barra)
                        </div>
                        <div style="border:1px solid #e67e22;border-top:none;padding:12px;
                                    border-radius:0 0 4px 4px;margin-bottom:12px;"
                             invisible="not detected_columns">
                            <div invisible="preview_html"
                                 style="color:#aaa;font-size:12px;padding:8px;text-align:center;">
                                Pulse <b>"👁 Vista previa"</b> en la barra superior para renderizar
                                el widget con sus datos reales antes de guardar.
                            </div>
                            <field name="preview_html" nolabel="1" readonly="1"
                                   invisible="not preview_html"
                                   widget="html" sanitize="0"/>
                        </div>

                        <!-- ── PASO 5 (opcional): Filtros post-SQL ── -->
                        <div style="background:#8e44ad;color:#fff;padding:6px 12px;
                                    border-radius:4px 4px 0 0;font-size:12px;font-weight:bold;">
                            Paso 5 (opcional) — Filtros post-SQL
                        </div>
                        <div style="border:1px solid #8e44ad;border-top:none;padding:12px;
                                    border-radius:0 0 4px 4px;margin-bottom:8px;">
                            <div style="font-size:12px;color:#888;margin-bottom:8px;">
                                Se aplican <b>después</b> de ejecutar el SQL.
                                Use el nombre exacto de la columna detectada.
                            </div>
                            <field name="filter_ids" nolabel="1">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="column_name" placeholder="nombre_columna"/>
                                    <field name="operator"/>
                                    <field name="value" placeholder="valor"/>
                                </list>
                            </field>
                        </div>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- ==================== LIST VIEW - WIDGET (embebida) ==================== -->
        <record id="view_nf_intelligence_widget_list" model="ir.ui.view">
            <field name="name">nf.intelligence.widget.list</field>
            <field name="model">nf.intelligence.widget</field>
            <field name="arch" type="xml">
                <list string="Widgets">
                    <field name="sequence" widget="handle"/>
                    <field name="name"/>
                    <field name="widget_type"/>
                    <field name="report_id"/>
                    <field name="label_field" string="Eje X / Filas" optional="show"/>
                    <field name="value_field" string="Valor" optional="show"/>
                    <field name="agg_func" optional="show"/>
                    <field name="col_width"/>
                </list>
            </field>
        </record>

        <!-- ==================== FORM VIEW - DASHBOARD ==================== -->
        <record id="view_nf_intelligence_dashboard_form" model="ir.ui.view">
            <field name="name">nf.intelligence.dashboard.form</field>
            <field name="model">nf.intelligence.dashboard</field>
            <field name="arch" type="xml">
                <form string="Dashboard">
                    <header>
                        <button name="action_view_dashboard"
                                type="object"
                                string="▶ Ver Dashboard"
                                class="btn-primary"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button class="oe_stat_button" icon="fa-th-large"
                                    type="object" name="action_view_dashboard">
                                <field name="widget_count" string="Widgets"
                                       widget="statinfo"/>
                            </button>
                        </div>
                        <div class="oe_title">
                            <label for="name" string="Dashboard"/>
                            <h1><field name="name" placeholder="Nombre del dashboard..."/></h1>
                        </div>
                        <group>
                            <field name="sequence"/>
                            <field name="description" placeholder="Descripción..."/>
                        </group>
                        <notebook>
                            <page string="Widgets" name="widgets">
                                <field name="widget_ids"
                                       views="[(False,'list'),(False,'form')]"/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- ==================== LIST VIEW - DASHBOARD ==================== -->
        <record id="view_nf_intelligence_dashboard_list" model="ir.ui.view">
            <field name="name">nf.intelligence.dashboard.list</field>
            <field name="model">nf.intelligence.dashboard</field>
            <field name="arch" type="xml">
                <list string="Dashboards">
                    <field name="sequence" widget="handle"/>
                    <field name="name"/>
                    <field name="description"/>
                    <field name="widget_count" string="Widgets"/>
                    <button name="action_view_dashboard"
                            type="object"
                            string="▶ Ver"
                            class="btn-primary btn-sm"
                            icon="fa-play"/>
                </list>
            </field>
        </record>

        <!-- ==================== ACTION - DASHBOARD ==================== -->
        <record id="action_nf_intelligence_dashboard" model="ir.actions.act_window">
            <field name="name">Dashboards</field>
            <field name="res_model">nf.intelligence.dashboard</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Crea tu primer dashboard
                </p>
                <p>
                    Combina múltiples widgets (tablas, gráficas, KPIs, pivot)
                    basados en tus reportes SQL existentes.
                </p>
            </field>
        </record>

    </data>
</odoo>
