<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Paperformat for 80mm thermal receipt -->
        <record id="paperformat_delivery_slip_receipt" model="report.paperformat">
            <field name="name">Delivery Slip Tirilla 80mm</field>
            <field name="format">custom</field>
            <field name="page_height">0</field>
            <field name="page_width">80</field>
            <field name="orientation">Portrait</field>
            <field name="margin_top">3</field>
            <field name="margin_bottom">3</field>
            <field name="margin_left">3</field>
            <field name="margin_right">3</field>
            <field name="header_line" eval="False"/>
            <field name="header_spacing">0</field>
            <field name="dpi">80</field>
            <field name="disable_shrinking" eval="True"/>
        </record>

        <!-- Report action on delivery orders -->
        <record id="action_report_delivery_slip_receipt" model="ir.actions.report">
            <field name="name">Entrega (Tirilla sin precios)</field>
            <field name="model">stock.picking</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">nf_delivery_slip_no_prices.report_delivery_slip_receipt</field>
            <field name="report_file">nf_delivery_slip_no_prices.report_delivery_slip_receipt</field>
            <field name="paperformat_id" ref="nf_delivery_slip_no_prices.paperformat_delivery_slip_receipt"/>
            <field name="binding_model_id" ref="stock.model_stock_picking"/>
            <field name="binding_type">report</field>
        </record>

        <record id="action_report_delivery_slip_receipt_with_prices" model="ir.actions.report">
            <field name="name">Entrega (Tirilla con precios)</field>
            <field name="model">stock.picking</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">nf_delivery_slip_no_prices.report_delivery_slip_receipt_with_prices</field>
            <field name="report_file">nf_delivery_slip_no_prices.report_delivery_slip_receipt_with_prices</field>
            <field name="paperformat_id" ref="nf_delivery_slip_no_prices.paperformat_delivery_slip_receipt"/>
            <field name="binding_model_id" ref="stock.model_stock_picking"/>
            <field name="binding_type">report</field>
        </record>

        <!-- QWeb template: Without Prices -->
        <template id="report_delivery_slip_receipt">
            <t t-call="web.basic_layout">
                <t t-foreach="docs" t-as="o">
                    <div class="page">
                        <style>
                            @page {
                                size: 80mm auto;
                                margin: 0mm;
                            }
                            * {
                                font-family: 'Courier New', Courier, monospace !important;
                                font-size: 11px !important;
                            }
                            body {
                                margin: 0;
                                padding: 0;
                                width: 80mm;
                            }
                            .page {
                                width: 80mm;
                                margin: 0;
                                padding: 3mm;
                            }
                            table {
                                width: 100%;
                                font-size: 10px;
                            }
                            hr {
                                border: none;
                                border-top: 1px dashed #000;
                                margin: 3mm 0;
                            }
                        </style>
                        <div style="text-align: center; margin-bottom: 8px;">
                            <img t-if="o.company_id.logo" t-att-src="image_data_uri(o.company_id.logo)" style="max-width: 150px; max-height: 60px; margin-bottom: 8px;"/>
                            <strong t-esc="o.company_id.name" style="display:block; margin-bottom: 4px;"/>
                            <div t-esc="o.company_id.partner_id.contact_address" style="margin-bottom: 4px;"/>
                            <div t-esc="o.company_id.phone" style="margin-bottom: 4px;"/>
                        </div>
                        <hr/>
                        <div>
                            <div><strong>Entrega/Remision:</strong> <span t-esc="o.name"/></div>
                            <div><strong>Fecha:</strong> <span t-esc="o.scheduled_date"/></div>
                            <div><strong>Responsable:</strong> <span t-esc="o.user_id.name or o.sale_id.user_id.name or o.create_uid.name"/></div>
                            <div><strong>Cliente:</strong> <span t-esc="o.partner_id.display_name"/></div>
                            <div><strong>Dirección:</strong> <span t-esc="o.partner_id.contact_address"/></div>
                        </div>
                        <hr/>
                        <table style="width: 100%;">
                            <thead>
                                <tr>
                                    <th style="text-align: left;">Producto</th>
                                    <th style="text-align: right;">Cant.</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="o.move_ids_without_package" t-as="line">
                                    <tr>
                                        <td>
                                            <span t-esc="line.product_id.display_name"/>
                                        </td>
                                        <td style="text-align: right;">
                                            <span t-esc="line.product_uom_qty"/>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                        <hr/>
                        <div style="text-align: center;">
                            <span>Entregado a satisfacción</span>
                        </div>
                    </div>
                </t>
            </t>
        </template>

        <!-- QWeb template: With Prices -->
        <template id="report_delivery_slip_receipt_with_prices">
            <t t-call="web.basic_layout">
                <t t-foreach="docs" t-as="o">
                    <div class="page">
                        <style>
                            @page {
                                size: 80mm auto;
                                margin: 0mm;
                            }
                            * {
                                font-family: 'Courier New', Courier, monospace !important;
                                font-size: 11px !important;
                            }
                            body {
                                margin: 0;
                                padding: 0;
                                width: 80mm;
                            }
                            .page {
                                width: 80mm;
                                margin: 0;
                                padding: 3mm;
                            }
                            table {
                                width: 100%;
                                font-size: 10px;
                            }
                            hr {
                                border: none;
                                border-top: 1px dashed #000;
                                margin: 3mm 0;
                            }
                        </style>
                        <div style="text-align: center; margin-bottom: 8px;">
                            <img t-if="o.company_id.logo" t-att-src="image_data_uri(o.company_id.logo)" style="max-width: 150px; max-height: 60px; margin-bottom: 8px;"/>
                            <strong t-esc="o.company_id.name" style="display:block; margin-bottom: 4px;"/>
                            <div t-esc="o.company_id.partner_id.contact_address" style="margin-bottom: 4px;"/>
                            <div t-esc="o.company_id.phone" style="margin-bottom: 4px;"/>
                        </div>
                        <hr/>
                        <div>
                            <div><strong>Entrega/Remision:</strong> <span t-esc="o.name"/></div>
                            <div><strong>Fecha:</strong> <span t-esc="o.scheduled_date"/></div>
                            <div><strong>Responsable:</strong> <span t-esc="o.user_id.name or o.sale_id.user_id.name or o.create_uid.name"/></div>
                            <div><strong>Cliente:</strong> <span t-esc="o.partner_id.display_name"/></div>
                            <div><strong>Dirección:</strong> <span t-esc="o.partner_id.contact_address"/></div>
                        </div>
                        <hr/>
                        <table style="width: 100%;">
                            <thead>
                                <tr>
                                    <th style="text-align: left; width: 40%;">Prod.</th>
                                    <th style="text-align: right; width: 15%;">Cant.</th>
                                    <th style="text-align: right; width: 20%;">Precio</th>
                                    <th style="text-align: right; width: 25%;">Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-set="total_prices" t-value="0"/>
                                <t t-foreach="o.move_ids_without_package" t-as="line">
                                    <t t-set="price_unit" t-value="line.sale_line_id.price_unit or 0.0"/>
                                    <t t-set="price_subtotal" t-value="price_unit * line.product_uom_qty"/>
                                    <t t-set="total_prices" t-value="total_prices + price_subtotal"/>
                                    <tr>
                                        <td>
                                            <span t-esc="line.product_id.name"/>
                                        </td>
                                        <td style="text-align: right;">
                                            <span t-esc="line.product_uom_qty"/>
                                        </td>
                                        <td style="text-align: right;">
                                            <span t-esc="price_unit" t-options='{"widget": "monetary", "display_currency": o.company_id.currency_id}'/>
                                        </td>
                                        <td style="text-align: right;">
                                            <span t-esc="price_subtotal" t-options='{"widget": "monetary", "display_currency": o.company_id.currency_id}'/>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                        <hr/>
                        <div style="text-align: right; font-weight: bold; font-size: 14px;">
                            <span>TOTAL: </span>
                            <span t-esc="total_prices" t-options='{"widget": "monetary", "display_currency": o.company_id.currency_id}'/>
                        </div>
                        <hr/>
                        <div style="text-align: center;">
                            <span>Entregado a satisfacción</span>
                        </div>
                    </div>
                </t>
            </t>
        </template>

        <!-- No inherit: leave original delivery slip untouched -->
    </data>
</odoo>
